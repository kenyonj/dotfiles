#!/bin/zsh
# Caches resolved 1Password secrets so new shells don't re-prompt.
# Cache is valid for 8 hours. Source this script, don't execute it.

CACHE_FILE="${TMPDIR:-/tmp}/.op-secrets-cache-$(id -u)"
CACHE_MAX_AGE=28800  # 8 hours in seconds
SOURCE_FILE="$HOME/.env-secrets"

_cache_is_fresh() {
  [[ -f "$CACHE_FILE" ]] || return 1
  local now=$(date +%s)
  local mtime=$(stat -f %m "$CACHE_FILE" 2>/dev/null)
  (( now - mtime < CACHE_MAX_AGE ))
}

if _cache_is_fresh; then
  source "$CACHE_FILE"
else
  local resolved
  resolved=$(op inject --in-file "$SOURCE_FILE" 2>/dev/null)
  if [[ $? -eq 0 && -n "$resolved" ]]; then
    install -m 600 /dev/null "$CACHE_FILE"
    echo "$resolved" > "$CACHE_FILE"
    source "$CACHE_FILE"
  else
    # op failed (user cancelled, not installed, etc.) — skip silently
    return 1
  fi
fi
